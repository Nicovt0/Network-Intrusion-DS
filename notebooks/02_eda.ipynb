    "df_attack = df[df['label'] == 1].copy()\n",
    "\n",
    "# Definir umbrales empíricos (P25 y P75 de ataques)\n",
    "low_ent_threshold = df_attack['entropy_mean'].quantile(0.25)\n",
    "low_vol_threshold = df_attack['bytes_sum'].quantile(0.25)\n",
    "\n",
    "high_ent_threshold = df_attack['entropy_mean'].quantile(0.75)\n",
    "high_vol_threshold = df_attack['bytes_sum'].quantile(0.75)\n",
    "\n",
    "def classify_attack_type(row):\n",
    "    if row['entropy_mean'] <= low_ent_threshold and row['bytes_sum'] <= low_vol_threshold:\n",
    "        return 'Low & Slow (Sigiloso)'\n",
    "    elif row['bytes_sum'] >= high_vol_threshold:\n",
    "        return 'Exfiltración Masiva'\n",
    "    else:\n",
    "        return 'Ataque Estándar'\n",
    "\n",
    "df_attack['attack_profile'] = df_attack.apply(classify_attack_type, axis=1)\n",
    "\n",
