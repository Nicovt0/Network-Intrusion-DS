    "profile = ProfileReport(\n",
    "    df[feat_cols + ['label']], \n",
    "    title='Reporte de Perfilado NIDS',\n",
    "    explorative=True,\n",
    "    minimal=True # Usamos minimal para que no colapse la memoria del navegador\n",
    ")\n",
    "profile.to_notebook_iframe()"
   ]
